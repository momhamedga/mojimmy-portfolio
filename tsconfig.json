{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    /* --- Ultra-Modern 2026 Security & Code Quality Rules --- */
    "noUnusedLocals": true, // يعترض لو فيه متغيرات متعرفة ومش مستخدمة
    "noUnusedParameters": true, // يعترض لو الـ Parameters بتاعة الدوال مش مستخدمة
    "noImplicitReturns": true, // يضمن إن كل مسارات الدالة بترجع قيمة
    "noFallthroughCasesInSwitch": true, // يمنع الأخطاء في جمل الـ Switch-Case
    "exactOptionalPropertyTypes": true, // يضمن إن الـ Optional Properties متخدش undefined بالخطأ
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "**/*.mts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
